{% extends 'base.html.twig' %}

{% block title %}Réinitialiser votre mot de passe{% endblock %}

{% block body %}

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">

                <div class="card shadow-sm">
                    <div class="card-body">

                        <h1 class="h4 text-center mb-4">Choisir un nouveau mot de passe</h1>

                        {{ form_start(resetForm) }}

                        <div class="mb-3">
                            {{ form_label(resetForm.plainPassword, 'Nouveau mot de passe', {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(resetForm.plainPassword, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(resetForm.plainPassword) }}
                        </div>

                        <div class="d-grid mt-4">
                            <button class="btn btn-primary">
                                Réinitialiser le mot de passe
                            </button>
                        </div>

                        {{ form_end(resetForm) }}

                    </div>
                </div>

            </div>
        </div>
    </div>

{% endblock %}
