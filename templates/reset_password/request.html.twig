{% extends 'base.html.twig' %}

{% block title %}Réinitialisation du mot de passe{% endblock %}

{% block body %}
    {% for flash_error in app.flashes('reset_password_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            {% for flash_error in app.flashes('reset_password_error') %}
                <div class="alert alert-danger text-center" role="alert">
                    {{ flash_error }}
                </div>
            {% endfor %}

            <div class="card shadow-sm">
                <div class="card-body">

                    <h1 class="h4 text-center mb-4">Réinitialiser votre mot de passe</h1>

                    {{ form_start(requestForm) }}

                    <div class="mb-3">
                        {{ form_label(requestForm.mail, 'Adresse e-mail', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(requestForm.mail, {'attr': {'class': 'form-control', 'placeholder': 'Votre adresse e-mail'}}) }}
                        {{ form_errors(requestForm.mail) }}
                    </div>

                    <div class="mb-3">
                        <small class="text-muted">
                            Saisissez votre adresse e-mail. Nous vous enverrons un lien permettant de réinitialiser votre mot de passe.
                        </small>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">
                            Envoyer le lien de réinitialisation
                        </button>
                    </div>

                    {{ form_end(requestForm) }}

                </div>
            </div>

        </div>
    </div>

{% endblock %}
