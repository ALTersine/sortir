{% extends 'base.html.twig' %}

{% block title %}{{ parent() }}Connexion{% endblock %}

{% block section %}
    <form method="post">
        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="mb-3">
                You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Logout</a>
            </div>
        {% endif %}

        <div class="d-flex flex-row mb-2">
            <label for="username" class="d-flex justify-content-start align-self-center col-1">Identifiant</label>
            <input type="text" value="{{ last_username }}" name="_username" id="username" class="form-control "
                   autocomplete="username" required autofocus>
        </div>
        <div class="d-flex flex-row mb-3">
            <label for="password" class="d-flex justify-content-start align-self-center col-1">Mot de passe</label>
            <input type="password" name="_password" id="password" class="form-control"
                   autocomplete="current-password col-10"
                   required>
        </div>
        <input type="hidden" name="_csrf_token" data-controller="csrf-protection"
               value="{{ csrf_token('authenticate') }}">

        <div class="d-flex flex-row mb-3 justify-content-center gap-4">
            <div class="">
                <button class="btn btn-lg btn-primary " type="submit">
                    Se connecter
                </button>
            </div>
            <div class="checkbox d-flex justify-content-around align-self-center gap-2">
                <input type="checkbox" name="_remember_me" id="_remember_me">
                <label for="_remember_me">Se souvenir de moi</label>
            </div>
        </div>

    </form>
{% endblock %}
